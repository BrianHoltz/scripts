import re
import sys
from pathlib import Path
from typing import Optional, Tuple

try:
    import piexif
    PIEXIF_AVAILABLE = True
except ImportError:
    PIEXIF_AVAILABLE = False
    piexif = None  # type: ignore


def extract_date_from_filename(filename: str) -> Optional[Tuple[str, str]]:
    """
    Extract date from filename and return (date_string, exif_datetime).
    
    Args:
        filename: The filename (not full path) to extract date from
        
    Returns:
        Tuple of (original_date_pattern, exif_datetime_string) or None if no match
        
    Date formats:
        YYYY-MM-DD → "YYYY:MM:DD 12:00:00"
        YYYYMMDD   → "YYYY:MM:DD 12:00:00"
        YYYY-MM    → "YYYY:MM:01 12:00:00"
        YYYYMM     → "YYYY:MM:01 12:00:00"
        YYYY       → "YYYY:07:15 12:00:00"
    """
    # Try YYYY-MM-DD first (with dashes)
    match = re.search(r'(\d{4})-(\d{2})-(\d{2})', filename)
    if match:
        year, month, day = match.groups()
        return (f"{year}-{month}-{day}", f"{year}:{month}:{day} 12:00:00")
    
    # Try YYYYMMDD (8 consecutive digits, no dashes)
    match = re.search(r'(?<!\d)(\d{8})(?!\d)', filename)
    if match:
        date_str = match.group(1)
        year = date_str[0:4]
        month = date_str[4:6]
        day = date_str[6:8]
        # Validate year, month, and day
        year_int = int(year)
        month_int = int(month)
        day_int = int(day)
        if 1900 <= year_int <= 2100 and 1 <= month_int <= 12 and 1 <= day_int <= 31:
            return (date_str, f"{year}:{month}:{day} 12:00:00")
    
    # Try YYYY-MM (with dashes)
    match = re.search(r'(\d{4})-(\d{2})', filename)
    if match:
        year, month = match.groups()
        return (f"{year}-{month}", f"{year}:{month}:01 12:00:00")
    
    # Try YYYYMM (6 consecutive digits, no dashes)
    match = re.search(r'(?<!\d)(\d{6})(?!\d)', filename)
    if match:
        date_str = match.group(1)
        year = date_str[0:4]
        month = date_str[4:6]
        # Validate year and month
        year_int = int(year)
        month_int = int(month)
        if 1900 <= year_int <= 2100 and 1 <= month_int <= 12:
            return (date_str, f"{year}:{month}:01 12:00:00")
    
    # Try YYYY (with non-digit boundaries to avoid matching parts of longer numbers)
    match = re.search(r'(?<!\d)(\d{4})(?!\d)', filename)
    if match:
        year = match.group(1)
        # Validate it's a reasonable year (1900-2100)
        if 1900 <= int(year) <= 2100:
            return (year, f"{year}:07:15 12:00:00")
    
    return None


def read_exif_dates(filepath: Path) -> bool:
    """
    Read and display EXIF date fields from an image file.
    
    Args:
        filepath: Path to the image file
        
    Returns:
        True if successful, False otherwise
    """
    if not PIEXIF_AVAILABLE:
        print("Error: piexif library not found. Install with: pip install piexif", file=sys.stderr)
        sys.exit(2)
    
    try:
        # Read existing EXIF data
        exif_dict = piexif.load(str(filepath))  # type: ignore
    except Exception as e:
        print(f"Error reading EXIF from {filepath}: {e}", file=sys.stderr)
        return False
    
    # Extract date fields
    date_time_original = None
    date_time = None
    date_time_digitized = None
    
    if "Exif" in exif_dict:
        if piexif.ExifIFD.DateTimeOriginal in exif_dict["Exif"]:  # type: ignore
            date_time_original = exif_dict["Exif"][piexif.ExifIFD.DateTimeOriginal].decode('ascii')  # type: ignore
        if piexif.ExifIFD.DateTimeDigitized in exif_dict["Exif"]:  # type: ignore
            date_time_digitized = exif_dict["Exif"][piexif.ExifIFD.DateTimeDigitized].decode('ascii')  # type: ignore
    
    if "0th" in exif_dict:
        if piexif.ImageIFD.DateTime in exif_dict["0th"]:  # type: ignore
            date_time = exif_dict["0th"][piexif.ImageIFD.DateTime].decode('ascii')  # type: ignore
    
    # Display results
    print(f"{filepath.name}:")
    print(f"  DateTimeOriginal:  {date_time_original if date_time_original else '(not set)'}")
    print(f"  DateTime:          {date_time if date_time else '(not set)'}")
    print(f"  DateTimeDigitized: {date_time_digitized if date_time_digitized else '(not set)'}")
    
    return True


def set_exif_dates(filepath: Path, exif_datetime: str, dry_run: bool = False) -> bool:
    """
    Set EXIF date fields in an image file.
    
    Args:
        filepath: Path to the image file
        exif_datetime: Date string in EXIF format "YYYY:MM:DD HH:MM:SS"
        dry_run: If True, don't actually modify the file
        
    Returns:
        True if successful (or would be successful in dry-run), False otherwise
    """
    if not PIEXIF_AVAILABLE:
        print("Error: piexif library not found. Install with: pip install piexif", file=sys.stderr)
        sys.exit(2)
    
    try:
        # Read existing EXIF data
        exif_dict = piexif.load(str(filepath))  # type: ignore
    except Exception as e:
        print(f"Error reading EXIF from {filepath}: {e}", file=sys.stderr)
        return False
    
    # Prepare date bytes
    date_bytes = exif_datetime.encode('ascii')
    
    # Set all date fields
    if "0th" not in exif_dict:
        exif_dict["0th"] = {}
    if "Exif" not in exif_dict:
        exif_dict["Exif"] = {}
    
    exif_dict["0th"][piexif.ImageIFD.DateTime] = date_bytes  # type: ignore
    exif_dict["Exif"][piexif.ExifIFD.DateTimeOriginal] = date_bytes  # type: ignore
    exif_dict["Exif"][piexif.ExifIFD.DateTimeDigitized] = date_bytes  # type: ignore
    
    if not dry_run:
        try:
            # Write EXIF data back to file
            exif_bytes = piexif.dump(exif_dict)  # type: ignore
            piexif.insert(exif_bytes, str(filepath))  # type: ignore
        except Exception as e:
            print(f"Error writing EXIF to {filepath}: {e}", file=sys.stderr)
            return False
    
    return True


