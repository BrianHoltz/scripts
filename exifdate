usage_msg = """\
NAME
    exifdate - read or set EXIF dates from filename date patterns

SYNOPSIS
    exifdate [OPTIONS] FILE [FILE ...]

DESCRIPTION
    By default, reads and displays EXIF date information from image files.
    --from-name extracts dates from filenames and writes in-place to EXIF fields.

    Supports five date formats in filenames:

      YYYY-MM-DD  (e.g., "2024-03-15") → sets date to 2024-03-15 12:00
      YYYYMMDD    (e.g., "20240315")   → sets date to 2024-03-15 12:00
      YYYY-MM     (e.g., "2024-03")    → sets date to 2024-03-01 12:00
      YYYYMM      (e.g., "202403")     → sets date to 2024-03-01 12:00
      YYYY        (e.g., "2024")       → sets date to 2024-07-15 12:00

    Sets all EXIF date fields: DateTimeOriginal, DateTime, DateTimeDigitized.

ARGUMENTS
    FILE                  One or more image files to process.

OPTIONS
    --from-name           Extract date from filename and write to EXIF fields.
    -n, --dryrun          Show what would be written without modifying files
                          (only valid with --from-name).
    -H, --raw-help        Show this raw usage text and exit.
    -h, --help            Show colorized usage and exit.

EXIT CODES
    0  success
    1  usage error (bad arguments)
    2  processing error (file not found, no date in filename, EXIF error)

EXAMPLES
    # Read and display EXIF dates
    exifdate IMG_2024-03-15_vacation.jpg

    # Show what would be written (dry-run)
    exifdate --from-name -n photo_2024-03-15.jpg

    # Write EXIF dates from filename
    exifdate --from-name photo_2024-03-15.jpg image_2024-03.jpg pic_2024.jpg

    # Process all JPEGs in current directory
    exifdate --from-name *.jpg

DATE EXTRACTION
    The tool searches for date patterns in the filename (not the full path).
    It tries patterns in order from most specific to least specific:
    YYYY-MM-DD, YYYYMMDD, YYYY-MM, YYYYMM, YYYY. First match wins.

    Examples:
      "vacation_2024-03-15_beach.jpg"  → 2024-03-15 12:00:00
      "IMG_20240315_123456.jpg"        → 2024-03-15 12:00:00
      "IMG_2024-03_spring.jpg"         → 2024-03-01 12:00:00
      "photo_202403_spring.jpg"        → 2024-03-01 12:00:00
      "photo_2024_summer.jpg"          → 2024-07-15 12:00:00

REQUIREMENTS
    Requires piexif library: pip install piexif

AUTHOR
    Brian Holtz (brian@holtz.org)
"""

# usage_msg is intentionally placed at the very top for human readers and future agents.
