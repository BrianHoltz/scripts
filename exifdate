def main() -> int:
    # Pre-scan for help flags only in the first argument position
    if len(sys.argv) > 1 and sys.argv[1] in ("-H", "--raw-help"):
        sys.stdout.write(usage_msg)
        return 0
    if len(sys.argv) > 1 and sys.argv[1] in ("-h", "--help"):
        show_usage()
        return 0

    # Check for piexif availability after help flags
    if not PIEXIF_AVAILABLE:
        print("Error: piexif library not found. Install with: pip install piexif", file=sys.stderr)
        return 2

    # Parse arguments
    args = sys.argv[1:]
    if not args:
        print("usage: exifdate [OPTIONS] FILE [FILE ...]", file=sys.stderr)
        print("Run 'exifdate -h' for help.", file=sys.stderr)
        return 1

    from_name = False
    dry_run = False
    files = []
    
    for arg in args:
        if arg == "--from-name":
            from_name = True
        elif arg in ("-n", "--dryrun"):
            dry_run = True
        elif arg.startswith("-"):
            print(f"Error: unknown option '{arg}'", file=sys.stderr)
            print("Run 'exifdate -h' for help.", file=sys.stderr)
            return 1
        else:
            files.append(arg)
    
    if not files:
        print("Error: no files specified", file=sys.stderr)
        print("Run 'exifdate -h' for help.", file=sys.stderr)
        return 1
    
    # Validate flag combinations
    if dry_run and not from_name:
        print("Error: -n/--dryrun can only be used with --from-name", file=sys.stderr)
        print("Run 'exifdate -h' for help.", file=sys.stderr)
        return 1

    # Process files based on mode
    if not from_name:
        # Default mode: read and display EXIF dates
        success_count = 0
        error_count = 0
        
        for filepath_str in files:
            filepath = Path(filepath_str)
            
            # Check if file exists
            if not filepath.exists():
                print(f"Error: file not found: {filepath}", file=sys.stderr)
                error_count += 1
                continue
            
            # Check if it's a file
            if not filepath.is_file():
                print(f"Error: not a file: {filepath}", file=sys.stderr)
                error_count += 1
                continue
            
            # Read and display EXIF dates
            if read_exif_dates(filepath):
                success_count += 1
            else:
                error_count += 1
            
            # Add blank line between files
            if filepath_str != files[-1]:
                print()
        
        # Return appropriate exit code
        if error_count > 0 and success_count == 0:
            return 2
        return 0
    
    else:
        # --from-name mode: extract from filename and write to EXIF
        if dry_run:
            print("exifdate: DRY RUN (remove -n to actually modify files)", file=sys.stderr)
            print()
        
        success_count = 0
        error_count = 0
        
        for filepath_str in files:
            filepath = Path(filepath_str)
            
            # Check if file exists
            if not filepath.exists():
                print(f"Error: file not found: {filepath}", file=sys.stderr)
                error_count += 1
                continue
            
            # Check if it's a file
            if not filepath.is_file():
                print(f"Error: not a file: {filepath}", file=sys.stderr)
                error_count += 1
                continue
            
            # Extract date from filename
            filename = filepath.name
            date_result = extract_date_from_filename(filename)
            
            if date_result is None:
                print(f"Error: no date pattern found in filename: {filename}", file=sys.stderr)
                error_count += 1
                continue
            
            date_pattern, exif_datetime = date_result
            
            # Set EXIF dates
            if set_exif_dates(filepath, exif_datetime, dry_run=dry_run):
                action = "Would set" if dry_run else "Set"
                print(f"{action} EXIF dates for {filepath.name}: {date_pattern} → {exif_datetime}")
                success_count += 1
            else:
                error_count += 1
        
        # Summary
        print()
        if dry_run:
            print(f"exifdate: would process {success_count} file(s), {error_count} error(s)", file=sys.stderr)
            if success_count > 0:
                print("exifdate: remove -n to actually modify files", file=sys.stderr)
        else:
            print(f"exifdate: processed {success_count} file(s), {error_count} error(s)", file=sys.stderr)
        
        # Return appropriate exit code
        if error_count > 0 and success_count == 0:
            return 2
        return 0


if __name__ == "__main__":
    raise SystemExit(main())

