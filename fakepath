def parse_args():
    import argparse
    p = argparse.ArgumentParser(add_help=False, exit_on_error=False)
    p.add_argument("path", help="Path to convert to key")
    p.add_argument("--parent-chars", type=int, default=60,
                   help="Max chars from parent directory (default: 60)")
    p.add_argument("--basename-chars", type=int, default=120,
                   help="Max chars from filename (default: 120)")
    p.add_argument("--hash-chars", type=int, default=8,
                   help="Hash suffix length (default: 8)")
    return p.parse_args()


def main() -> int:
    # Pre-scan for help flags only in the first argument position
    if len(sys.argv) > 1 and sys.argv[1] in ("-H", "--raw-help"):
        sys.stdout.write(usage_msg)
        return 0
    if len(sys.argv) > 1 and sys.argv[1] in ("-h", "--help"):
        show_usage()
        return 0

    try:
        args = parse_args()
    except (argparse.ArgumentError, SystemExit):
        print("usage: fakepath PATH [--parent-chars N] [--basename-chars M] [--hash-chars H]",
              file=sys.stderr)
        print("Run 'fakepath -h' for help.", file=sys.stderr)
        return 1

    try:
        result = fakepath(args.path, args.parent_chars, args.basename_chars, args.hash_chars)
        print(result)
        return 0
    except ValueError as e:
        print(f"Error: {e}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
