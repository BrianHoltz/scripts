usage_msg = """\
NAME
    fakepath - generate human-readable filesystem keys from absolute paths

SYNOPSIS
    fakepath PATH [--parent-chars N] [--basename-chars M] [--hash-chars H]

DESCRIPTION
    Generates a collision-free, human-readable key from an absolute file path
    for use in lock/hold/tag systems and marker filenames.

    The key encodes the parent directory path (truncated), the basename
    (truncated), and a short hash of the full canonical path for collision
    resistance. Result fits in filesystem filename limits (< 255 chars).

    Deterministic: same input always produces same output.

ARGUMENTS
    PATH                  Absolute file path (or relative; will be resolved
                          to canonical form).

OPTIONS
    --parent-chars N      Maximum characters from parent directory path
                          (default: 60).
    --basename-chars M    Maximum characters from filename (default: 120).
    --hash-chars H        Length of hash suffix in hex (default: 8).

    -H, --raw-help        Show this raw usage text and exit
    -h, --help            Show colorized usage and exit

OUTPUT
    A string of the form: <parent>_<basename>_<hash>

    Parent: first N chars of parent directory path, with / replaced by _
    Basename: first M chars of filename
    Hash: first H hex digits of sha256(canonical_path)

EXIT CODES
    0  success
    1  usage error (bad arguments)
    2  path resolution failed (nonexistent or unresolvable path)

EXAMPLES
    fakepath /Users/alice/src/project/README.md
    # Output: Users_alice_src_project_README.md_abc123de

    fakepath ./relative/path/file.txt --parent-chars 40 --basename-chars 100
    # Resolves ./relative/path to canonical, applies custom truncation

    fakepath /very/long/directory/structure/file.txt --hash-chars 12
    # Uses longer hash suffix (12 hex chars instead of 8)

INTEGRATION
    To use fakepath in another Python script for generating lock keys:

      import subprocess
      from pathlib import Path
      import hashlib

      def get_lock_key(path: Path) -> str:
          try:
              result = subprocess.run(["fakepath", str(path)],
                  capture_output=True, text=True, timeout=5)
              if result.returncode == 0:
                  return result.stdout.strip()
          except Exception:
              pass
          return hashlib.sha256(str(path.resolve()).encode()).hexdigest()[:24]

    This pattern tries fakepath first (human-readable format), falls back to
    a simple hash if fakepath is unavailable or the path doesn't exist.
"""

# usage_msg is intentionally placed at the very top for human readers and future agents.
# usage_msg formatting and content ALWAYS trumps show_usage(). If you change usage_msg,
# you MUST update show_usage() to match it EXACTLY, including newlines and spacing.

import argparse
import sys
from pathlib import Path


def fakepath(path: str, parent_chars: int = 60, basename_chars: int = 120, hash_chars: int = 8) -> str:
    """
    Generate a human-readable, collision-free filesystem key from a path.

    Args:
        path: Absolute or relative file path
        parent_chars: Max chars from parent directory (default: 60)
        basename_chars: Max chars from filename (default: 120)
        hash_chars: Length of hash suffix (default: 8)

    Returns:
        String of form: <parent>_<basename>_<hash>

    Raises:
        ValueError: if path cannot be resolved or parameters are invalid
    """
    import hashlib

    # Validate parameters
    if not path:
        raise ValueError("path cannot be empty")
    if parent_chars < 0:
        raise ValueError("parent_chars must be >= 0")
    if basename_chars <= 0:
        raise ValueError("basename_chars must be > 0")
    if hash_chars <= 0:
        raise ValueError("hash_chars must be > 0")

    # Resolve to canonical absolute path
    try:
        resolved = Path(path).resolve(strict=True)
    except (OSError, RuntimeError, FileNotFoundError) as e:
        raise ValueError(f"Cannot resolve path '{path}': {e}")

    # Extract parent directory and basename
    parent_str = str(resolved.parent)
    basename_str = resolved.name

    # Replace "/" with "_" in parent, truncate to parent_chars
    parent_normalized = parent_str.replace("/", "_")
    parent_part = parent_normalized[:parent_chars]

    # Truncate basename to basename_chars
    basename_part = basename_str[:basename_chars]

    # Compute hash of full canonical path
    full_path_str = str(resolved)
    path_hash = hashlib.sha256(full_path_str.encode("utf-8")).hexdigest()[:hash_chars]

    # Combine: parent_basename_hash
    return f"{parent_part}_{basename_part}_{path_hash}"


def show_usage() -> None:
    RESET = "\033[0m"
    BOLD = "\033[1m"
    UNDERLINE = "\033[4m"
    ITALIC = "\033[3m"
    CMD = "\033[1;38;5;33m"        # DodgerBlue #1E90FF
    FLAG = "\033[38;5;51m"         # DeepSkyBlue #00BFFF
    FS_VAR = "\033[38;5;78m"       # MediumSeaGreen #3CB371
    FS_LIT = "\033[1;38;5;46m"     # Lime #00FF00
    ARG_VAR = "\033[38;5;214m"     # Orange #FFA500
    ARG_LIT = "\033[38;5;208m"     # DarkOrange #FF8C00
    W = sys.stdout.write
    NL = "\n"

    def section(title: str) -> None:
        W(f"{BOLD}{UNDERLINE}{title}{RESET}{NL}")

    def cmd(s: str) -> str:
        return f"{CMD}{s}{RESET}"

    def flag(s: str) -> str:
        return f"{FLAG}{s}{RESET}"

    def fs_var(s: str) -> str:
        return f"{FS_VAR}{UNDERLINE}{ITALIC}{s}{RESET}"

    def fs_lit(s: str) -> str:
        return f"{FS_LIT}{UNDERLINE}{s}{RESET}"

    def arg_var(s: str) -> str:
        return f"{ARG_VAR}{ITALIC}{s}{RESET}"

    def arg_lit(s: str) -> str:
        return f"{ARG_LIT}{s}{RESET}"

