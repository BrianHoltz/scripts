    W(NL)

    section("DESCRIPTION")
    W(f"    Generates a collision-free, human-readable key from an absolute file path{NL}")
    W(f"    for use in lock/hold/tag systems and marker filenames.{NL}")
    W(NL)
    W(f"    The key encodes the parent directory path (truncated to {arg_lit('N')} chars),{NL}")
    W(f"    the basename (truncated to {arg_lit('M')} chars), and a short hash of the{NL}")
    W(f"    full canonical path for collision resistance.{NL}")
    W(NL)
    W(f"    Deterministic: same input always produces same output.{NL}")
    W(NL)

    section("ARGUMENTS")
    W(f"    {fs_var('PATH')}                  Absolute file path (or relative; will be resolved{NL}")
    W(f"                          to canonical form).{NL}")
    W(NL)

    section("OPTIONS")
    W(f"    {flag('--parent-chars')} {arg_var('N')}      Maximum characters from parent directory path{NL}")
    W(f"                          (default: {arg_lit('60')}).{NL}")
    W(f"    {flag('--basename-chars')} {arg_var('M')}    Maximum characters from filename{NL}")
    W(f"                          (default: {arg_lit('120')}).{NL}")
    W(f"    {flag('--hash-chars')} {arg_var('H')}        Length of hash suffix in hex{NL}")
    W(f"                          (default: {arg_lit('8')}).{NL}")
    W(NL)
    W(f"    {flag('-H')}, {flag('--raw-help')}        Show this raw usage text and exit{NL}")
    W(f"    {flag('-h')}, {flag('--help')}            Show colorized usage and exit{NL}")
    W(NL)

    section("OUTPUT")
    W(f"    A string of the form: {arg_var('<parent>')}_{arg_var('<basename>')}_{arg_var('<hash>')}{NL}")
    W(NL)
    W(f"    Parent: first {arg_lit('N')} chars of parent directory path, with {arg_lit('/')} replaced by {arg_lit('_')}{NL}")
    W(f"    Basename: first {arg_lit('M')} chars of filename{NL}")
    W(f"    Hash: first {arg_lit('H')} hex digits of sha256(canonical_path){NL}")
