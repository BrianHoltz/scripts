    W(f"    {cmd('fakepath')} - generate human-readable filesystem keys from paths{NL}")
    W(NL)

    section("SYNOPSIS")
    W(f"    {cmd('fakepath')} {fs_var('PATH')} [{flag('--parent-chars')} {arg_var('N')}]"
