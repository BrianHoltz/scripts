usage_msg = """\
NAME
    commitz_ui - Deterministic pending-commit menu renderer

SYNOPSIS
    commitz_ui [OPTIONS]

OPTIONS
    -h, --help            Show colorized usage and exit
    -H, --raw-help        Show this raw usage text (for diff/testing) and exit

DESCRIPTION
    Stub version: currently implements only the help/raw-help contract.
"""

# usage_msg is intentionally placed at the top for human readers and future agents.
# usage_msg formatting and content ALWAYS trumps show_usage(). If you change
# usage_msg, update show_usage() to match it exactly.

import sys


def show_usage() -> None:
    RESET = "\033[0m"
    BOLD = "\033[1m"
    UNDERLINE = "\033[4m"
    CMD_COLOR = "\033[1;34m"
    FLAG_COLOR = "\033[1;36m"

    print(f"{BOLD}{UNDERLINE}NAME{RESET}")
    print(f"    {CMD_COLOR}commitz_ui{RESET} - Deterministic pending-commit menu renderer")
    print()
    print(f"{BOLD}{UNDERLINE}SYNOPSIS{RESET}")
    print(f"    {CMD_COLOR}commitz_ui{RESET} [{FLAG_COLOR}OPTIONS{RESET}]")
    print()
    print(f"{BOLD}{UNDERLINE}OPTIONS{RESET}")
    print(f"    {FLAG_COLOR}-h{RESET}, {FLAG_COLOR}--help{RESET}            Show colorized usage and exit")
    print(f"    {FLAG_COLOR}-H{RESET}, {FLAG_COLOR}--raw-help{RESET}        Show this raw usage text (for diff/testing) and exit")
    print()
    print(f"{BOLD}{UNDERLINE}DESCRIPTION{RESET}")
    print("    Stub version: currently implements only the help/raw-help contract.")


def show_usage_raw() -> None:
    print(usage_msg, end="")


def main(argv: list[str]) -> int:
    if len(argv) > 1 and argv[1] in ("-H", "--raw-help"):
        show_usage_raw()
        return 0
    if len(argv) > 1 and argv[1] in ("-h", "--help"):
        show_usage()
        return 0

    print("commitz_ui: stub implementation; use -h for help", file=sys.stderr)
    return 1


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
