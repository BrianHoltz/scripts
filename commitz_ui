usage_msg = """\
NAME
    commitz_ui - Deterministic pending-commit menu renderer

SYNOPSIS
    commitz_ui [OPTIONS]

OPTIONS
    -h, --help            Show colorized usage and exit
    -H, --raw-help        Show this raw usage text (for diff/testing) and exit
    --mirror              Use mirror wording in P action
    --no-mirror           Use push-only wording in P action

DESCRIPTION
    Renders a deterministic commit/push UI based on git status and upstream delta.
    Output shape is computed from git state; no freehand inventory.
"""

# usage_msg is intentionally placed at the top for human readers and future agents.
# usage_msg formatting and content ALWAYS trumps show_usage(). If you change
# usage_msg, update show_usage() to match it exactly.

import sys
import os
import subprocess
from pathlib import Path


def show_usage() -> None:
    show_usage_raw()


def show_usage_raw() -> None:
    print(usage_msg, end="")


def run_git(args: list[str]) -> subprocess.CompletedProcess:
    return subprocess.run(["git", *args], capture_output=True, text=True)


def basename(path_text: str) -> str:
    return Path(path_text).name


def parse_status_lines(lines: list[str]) -> list[str]:
    entries: list[str] = []
    for line in lines:
        if not line:
            continue
        if line.startswith("?? "):
            entries.append(f"{basename(line[3:])}: untracked")
            continue
        if len(line) < 4:
            continue
        x = line[0]
        y = line[1]
        path_part = line[3:]

        if " -> " in path_part and (x == "R" or y == "R"):
            old_path, new_path = path_part.split(" -> ", 1)
            entries.append(f"{basename(old_path)} -> {basename(new_path)}: renamed")
            continue

        if x == "D" or y == "D":
            entries.append(f"[del] {basename(path_part)}: deleted")
            continue

        if x == "A" or y == "A":
            entries.append(f"{basename(path_part)}: added")
            continue

        entries.append(f"{basename(path_part)}: modified")
    return entries


def get_unpushed_count() -> int:
    cp = run_git(["rev-list", "--count", "@{u}..HEAD"])
    if cp.returncode != 0:
        return 0
    txt = cp.stdout.strip()
    try:
        return int(txt)
    except ValueError:
        return 0


def use_mirror(argv: list[str]) -> bool:
    if "--mirror" in argv:
        return True
    if "--no-mirror" in argv:
        return False
    return os.getenv("COMMITZ_UI_MIRROR", "").strip() == "1"


def render(lines: list[str], unpushed_count: int, mirror: bool) -> str:
    p_push = "push+mirror" if mirror else "push"
    p_commit_push = "commit+push+mirror" if mirror else "commit+push"

    out: list[str] = []
    if not lines and unpushed_count > 0:
        out.append(f"Commits not yet pushed: {unpushed_count}.")
        out.append(f"P: {p_push}. Or ignore & keep prompting.")
        return "\n".join(out) + "\n"

    if lines:
        out.append("Pending commits. Select with e.g. 1,3-7 or omit for all.")
        for i, item in enumerate(lines, start=1):
            out.append(f"{i}. {item}")

        if unpushed_count > 0:
            out.append("")
            out.append(f"Commits not yet pushed: {unpushed_count}.")

        out.append(f"C: commit. P: {p_commit_push}. Or ignore & keep prompting.")
        return "\n".join(out) + "\n"

    out.append("No uncommitted changes or unpushed commits.")
    return "\n".join(out) + "\n"


def main(argv: list[str]) -> int:
    if len(argv) > 1 and argv[1] in ("-H", "--raw-help"):
        show_usage_raw()
        return 0
    if len(argv) > 1 and argv[1] in ("-h", "--help"):
        show_usage()
        return 0

    if "--mirror" in argv and "--no-mirror" in argv:
        print("commitz_ui: choose either --mirror or --no-mirror", file=sys.stderr)
        return 1

    if len(argv) > 1:
        unknown = [a for a in argv[1:] if a not in ("--mirror", "--no-mirror")]
        if unknown:
            print(f"commitz_ui: unknown argument: {unknown[0]}", file=sys.stderr)
            return 1

    status_cp = run_git(["status", "--porcelain=v1"])
    if status_cp.returncode != 0:
        print("commitz_ui: must be run inside a git repository", file=sys.stderr)
        return 1

    status_lines = status_cp.stdout.splitlines()
    entries = parse_status_lines(status_lines)
    unpushed_count = get_unpushed_count()
    print(render(entries, unpushed_count, use_mirror(argv)), end="")
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
