usage_msg = """\
NAME
    commitz_ui - Deterministic pending-commit menu renderer

SYNOPSIS
    commitz_ui [OPTIONS]

OPTIONS
    -h, --help            Show colorized usage and exit
    -H, --raw-help        Show this raw usage text (for diff/testing) and exit

DESCRIPTION
    Renders a deterministic commit/push UI based on git status and upstream delta.
    Output shape is computed from git state; no freehand inventory.
"""

# usage_msg is intentionally placed at the top for human readers and future agents.
# usage_msg formatting and content ALWAYS trumps show_usage(). If you change
# usage_msg, update show_usage() to match it exactly.

import sys
import subprocess
from pathlib import Path
from typing import Optional
from datetime import datetime


def show_usage() -> None:
    show_usage_raw()


def show_usage_raw() -> None:
    print(usage_msg, end="")


def run_git(args: list[str]) -> subprocess.CompletedProcess:
    return subprocess.run(["git", *args], capture_output=True, text=True)


def basename(path_text: str) -> str:
    return Path(path_text).name


def change_brief(path_text: str) -> str:
    cp = run_git(["diff", "--numstat", "HEAD", "--", path_text])
    if cp.returncode != 0:
        return "modified"
    line = cp.stdout.strip().splitlines()
    if not line:
        return "modified"
    parts = line[0].split("\t")
    if len(parts) < 2:
        return "modified"
    adds = parts[0]
    dels = parts[1]
    if adds.isdigit() and dels.isdigit():
        return f"+{adds}/-{dels}"
    return "modified"


def parse_status_lines(lines: list[str]) -> tuple[list[str], int]:
    entries: list[str] = []
    untracked_count: int = 0
    for line in lines:
        if not line:
            continue
        if line.startswith("?? "):
            untracked_count += 1
            continue
        if len(line) < 4:
            continue
        x = line[0]
        y = line[1]
        path_part = line[3:]

        if " -> " in path_part and (x == "R" or y == "R"):
            old_path, new_path = path_part.split(" -> ", 1)
            entries.append(f"{basename(old_path)} -> {basename(new_path)}: renamed")
            continue

        if x == "D" or y == "D":
            entries.append(f"[del] {basename(path_part)}: deleted")
            continue

        if x == "A" or y == "A":
            entries.append(f"{basename(path_part)}: added")
            continue

        entries.append(f"{basename(path_part)} {change_brief(path_part)}")
    return entries, untracked_count


def get_unpushed_count() -> int:
    cp = run_git(["rev-list", "--count", "@{u}..HEAD"])
    if cp.returncode != 0:
        return 0
    txt = cp.stdout.strip()
    try:
        return int(txt)
    except ValueError:
        return 0


def get_oldest_unpushed_timestamp() -> Optional[str]:
    """Return formatted 'yyyy.mm.dd.Dow.hhmm' for oldest unpushed commit, or None if none."""
    cp = run_git(["log", "@{u}..HEAD", "--format=%ai"])
    if cp.returncode != 0 or not cp.stdout.strip():
        return None
    lines = cp.stdout.strip().splitlines()
    if not lines:
        return None
    oldest_iso = lines[-1]  # last line is oldest (reverse chronological)
    # Format: "2026-04-12 15:47:23 -0700"
    try:

        dt = datetime.fromisoformat(oldest_iso.split()[0])
        dow_short = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"][dt.weekday()]
        return dt.strftime(f"%Y.%m.%d.{dow_short}.%H%M")
    except (ValueError, IndexError):
        return None


def get_commits_to_merge_count() -> int:
    """Return count of commits on upstream not locally (HEAD..@{u})."""
    cp = run_git(["rev-list", "--count", "HEAD..@{u}"])
    if cp.returncode != 0:
        return 0
    txt = cp.stdout.strip()
    try:
        return int(txt)
    except ValueError:
        return 0


def get_merge_conflict_files() -> list[str]:
    """Return list of files with merge conflicts (during active merge)."""
    cp = run_git(["diff", "--name-only", "--diff-filter=U"])
    if cp.returncode != 0:
        return []
    return cp.stdout.strip().splitlines()


def render(lines: list[str], untracked_count: int, unpushed_count: int) -> str:
    p_push = "push"
    p_commit_push = "commit+push"
    
    # Detect merge state and upstream delta
    to_merge_count = get_commits_to_merge_count()
    conflict_files = get_merge_conflict_files()

    out: list[str] = []
    if not lines and (unpushed_count > 0 or to_merge_count > 0 or conflict_files):
        out: list[str] = []
        if conflict_files:
            conflicts_noun = "file" if len(conflict_files) == 1 else "files"
            out.append(f"{len(conflict_files)} {conflicts_noun} with merge conflicts (resolve before commit).")
        if to_merge_count > 0:
            merge_noun = "commit" if to_merge_count == 1 else "commits"
            out.append(f"{to_merge_count} {merge_noun} to merge from upstream.")
        if unpushed_count > 0:
            noun = "commit" if unpushed_count == 1 else "commits"
            oldest_ts = get_oldest_unpushed_timestamp()
            ts_text = f" since {oldest_ts}" if oldest_ts else ""
            out.append(f"{unpushed_count} {noun} already in next push{ts_text}.")
        out.append(f"P: {p_push}. Or ignore & keep prompting.")
        return "\n".join(out) + "\n"

    if lines:
        pending_count = len(lines)
        file_noun = "file" if pending_count == 1 else "files"
        if pending_count == 1:
            out.append(f"{pending_count} {file_noun} to commit.")
        else:
            out.append(f"{pending_count} {file_noun} to commit. Select buckets with e.g. 1,3-7 or omit for all.")
        for i, item in enumerate(lines, start=1):
            out.append(f"{i}. {item}")

        if untracked_count > 0 or unpushed_count > 0 or to_merge_count > 0 or conflict_files:
            out.append("")
        if untracked_count > 0:
            ut_noun = "file" if untracked_count == 1 else "files"
            out.append(f"{untracked_count} untracked {ut_noun} (not staged).")
        if conflict_files:
            conflicts_noun = "file" if len(conflict_files) == 1 else "files"
            out.append(f"{len(conflict_files)} {conflicts_noun} with merge conflicts (resolve before commit).")
        if to_merge_count > 0:
            merge_noun = "commit" if to_merge_count == 1 else "commits"
            out.append(f"{to_merge_count} {merge_noun} to merge from upstream.")
        if unpushed_count > 0:
            unpushed_noun = "commit" if unpushed_count == 1 else "commits"
            oldest_ts = get_oldest_unpushed_timestamp()
            ts_text = f" since {oldest_ts}" if oldest_ts else ""
            out.append(f"{unpushed_count} {unpushed_noun} already in next push{ts_text}.")

        out.append(f"C: commit. P: {p_commit_push}. Or ignore & keep prompting.")
        return "\n".join(out) + "\n"

    out.append("No uncommitted changes or unpushed commits.")
    return "\n".join(out) + "\n"


def main(argv: list[str]) -> int:
    if len(argv) > 1 and argv[1] in ("-H", "--raw-help"):
        show_usage_raw()
        return 0
    if len(argv) > 1 and argv[1] in ("-h", "--help"):
        show_usage()
        return 0

    if len(argv) > 1:
        unknown = list(argv[1:])
        if unknown:
            print(f"commitz_ui: unknown argument: {unknown[0]}", file=sys.stderr)
            return 1

    status_cp = run_git(["status", "--porcelain=v1"])
    if status_cp.returncode != 0:
        print("commitz_ui: must be run inside a git repository", file=sys.stderr)
        return 1

    status_lines = status_cp.stdout.splitlines()
    entries, untracked_count = parse_status_lines(status_lines)
    unpushed_count = get_unpushed_count()
    print(render(entries, untracked_count, unpushed_count), end="")
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
