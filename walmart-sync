# ---------------------------------------------------------------------------
# Portability check — patterns that signal Walmart-internal content
# ---------------------------------------------------------------------------
INTERNAL_PATTERNS = [
    # Internal corp hostnames (not gecgithub01 — already public-knowledge)
    (r"\b[\w-]+\.corp\.walmart\.com\b", "internal corp hostname"),
    (r"\bspark\.walmart\.com\b",        "internal Spark hostname"),
    (r"\bpc03\.my\.snyk\.io\b",         "internal Snyk hostname"),
    # Jira project keys — reveal internal project names/work
    (r"\b(?:GENAICA|GENAITK|WICN|CATS|SUPP)-\d+\b", "internal Jira ticket ID"),
    # Internal SSP/Kitt/WCNP config markers
    (r"\bkitt\.ya?ml\b",               "Kitt config (WCNP-specific)"),
]

# ---------------------------------------------------------------------------
# Ref-integrity check — references that break on personal laptop
# ---------------------------------------------------------------------------
REF_INTEGRITY_PATTERNS = [
    # Filesystem paths that only exist on work laptop
    (r"~/src/relationship-shared",      "~/src/relationship-shared (work laptop only)"),
    (r'\$HOME/src/relationship-shared', "$HOME/src/relationship-shared (work laptop only)"),
    # shared/.wibey as local symlink — only flag when not inside a URL (no http/https before it)
    # Uses a custom match function; here we match then filter in grep_patterns_no_url()
    # (implemented as a separate pass below)
    # (doc-audit is now mirrored — no ref-integrity check needed)
]

# Patterns checked with URL-exclusion (line must not contain http/https before the match)
REF_INTEGRITY_PATH_PATTERNS = [
    (r'\bshared/\.wibey\b', "shared/ symlink path (work laptop only)"),
]

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
GREEN  = "\033[32m"
RED    = "\033[31m"
YELLOW = "\033[33m"
CYAN   = "\033[36m"
RESET  = "\033[0m"
BOLD   = "\033[1m"

def c(color, text): return f"{color}{text}{RESET}"

def collect_files(path: Path):
    """Return list of Path objects under path (or [path] if file)."""
    if path.is_file():
        return [path]
    if path.is_dir():
        return sorted(path.rglob("*"))
    return []

def grep_patterns(file_path: Path, patterns):
    """Return list of (lineno, line, label) hits."""
    hits = []
    try:
        text = file_path.read_text(errors="replace")
    except Exception:
        return hits
    for lineno, line in enumerate(text.splitlines(), 1):
        for pat, label in patterns:
            if re.search(pat, line, re.IGNORECASE):
                hits.append((lineno, line.rstrip(), label))
                break  # one label per line
    return hits

def grep_path_patterns(file_path: Path, patterns):
    """Like grep_patterns but skips lines that contain a URL before the match."""
    hits = []
    try:
        text = file_path.read_text(errors="replace")
    except Exception:
        return hits
    url_re = re.compile(r'https?://', re.IGNORECASE)
    for lineno, line in enumerate(text.splitlines(), 1):
        if url_re.search(line):
            continue  # skip lines that are URLs/links (they're portability hits, not ref hits)
        for pat, label in patterns:
            if re.search(pat, line, re.IGNORECASE):
                hits.append((lineno, line.rstrip(), label))
                break
    return hits

# ---------------------------------------------------------------------------
# Git helpers
# ---------------------------------------------------------------------------
def run_git_in(repo: Path, *args, capture=True):
    """Run a git command in `repo`, returning CompletedProcess."""
    cmd = ["git", "-C", str(repo)] + list(args)
    if capture:
        return subprocess.run(cmd, capture_output=True, text=True)
    return subprocess.run(cmd)

def run_git(*args, capture=True):
    """Run a git command in ~/bin/, returning CompletedProcess."""
    return run_git_in(BIN, *args, capture=capture)

def parse_porcelain_paths(porcelain_text: str):
    """Return normalized file paths from `git status --porcelain` output."""
    paths = []
    for raw in porcelain_text.splitlines():
        if len(raw) < 4:
            continue
        path = raw[3:]
        if " -> " in path:  # rename/copy form: old -> new
            path = path.split(" -> ", 1)[1]
        paths.append(path.strip())
    return paths

def walmart_sync_path_specs():
    """Return (exact_paths, directory_prefixes) for files managed by walmart-sync."""
    exact = {"walmart-sync"} | set(PORTABILITY_PUSH_EXEMPT)
    prefixes = []
    for _, bin_rel, is_dir in MIRROR_ITEMS:
        if is_dir:
            prefixes.append(bin_rel.rstrip("/") + "/")
        else:
            exact.add(bin_rel)
    for item in PERSONAL_ONLY:
        if item.endswith("/"):
            prefixes.append(item.rstrip("/") + "/")
        else:
            exact.add(item)
    return exact, prefixes

def is_walmart_sync_managed(path: str):
    exact, prefixes = walmart_sync_path_specs()
    if path in exact:
        return True
    return any(path.startswith(prefix) for prefix in prefixes)

def block_if_managed_changes(action_label: str):
    """
    Enforce commit-first policy for walmart-sync-managed files.
    Returns True when safe to proceed; prints guidance and returns False otherwise.
    """
    status = run_git("status", "--porcelain")
    dirty_paths = parse_porcelain_paths(status.stdout)
    managed = [p for p in dirty_paths if is_walmart_sync_managed(p)]
    if not managed:
        return True

    print(c(RED + BOLD, f"⚠ Commit-first policy: cannot {action_label} with local walmart-sync changes."))
    print(c(RED, "Commit these files first, then rerun walmart-sync:"))
    for p in managed:
        print(f"  - {p}")
    print()
    print(c(CYAN, "Suggested:"))
    print(c(CYAN, "  cd ~/bin && git add <files> && git commit"))
    return False

def detect_upstream(repo=BIN):
    """Return (remote, branch) for repo HEAD upstream, or ('origin', current_branch)."""
    r = run_git_in(repo, "rev-parse", "--abbrev-ref", "HEAD@{upstream}")
    if r.returncode == 0:
        parts = r.stdout.strip().split("/", 1)
        if len(parts) == 2:
            return parts[0], parts[1]
    branch_r = run_git_in(repo, "branch", "--show-current")
    branch = branch_r.stdout.strip() or "main"
    return "origin", branch

def list_dirty_paths(repo=BIN):
    status = run_git_in(repo, "status", "--porcelain")
    return parse_porcelain_paths(status.stdout)

def pull_repo(repo: Path, label: str):
    """Commit-first pull: refuse dirty tree, then pull (merge, not rebase)."""
    dirty = list_dirty_paths(repo)
    if dirty:
        print(c(RED + BOLD, f"⚠ Commit-first policy: cannot pull {label} with local changes."))
        print(c(RED, "Commit these files first, then rerun walmart-sync:"))
        for p in dirty:
            print(f"  - {p}")
        print()
        print(c(CYAN, f"Suggested: cd {repo} && git add <files> && git commit"))
        return False

    remote, branch = detect_upstream(repo=repo)
    print(c(CYAN, f"Pulling {label} from {remote}/{branch} (merge)…"))
    r = run_git_in(repo, "pull", "--no-rebase", remote, branch, capture=False)
    if r.returncode != 0:
        print()
        print(c(RED + BOLD, f"⚠⚠ AGENT ALERT: git pull failed for {label}."))
        print(c(RED, "Resolve conflicts, then re-run walmart-sync."))
        return False
    return True

def do_pull():
    """Personal laptop: check git state then pull from origin (merge, not rebase)."""
    if not block_if_managed_changes("pull"):
        sys.exit(1)
    if not pull_repo(BIN, "~/bin/"):
        sys.exit(1)

def do_push():
    """Work laptop: portability gate on unpushed commits, then push to origin."""
    if not block_if_managed_changes("push"):
        sys.exit(1)

    remote, branch = detect_upstream()

    ahead_r = run_git("rev-list", "--count", "HEAD@{upstream}..HEAD")
    if ahead_r.returncode != 0:
        print(c(YELLOW, "Cannot determine upstream. Set one with: git branch --set-upstream-to=origin/main"))
        sys.exit(1)
    ahead = int(ahead_r.stdout.strip() or "0")
    if ahead == 0:
        print(c(YELLOW, "Nothing to push (no commits ahead of upstream)."))
        return

    log = run_git("log", "--oneline", "HEAD@{upstream}..HEAD")
    print(c(CYAN, f"Scanning {ahead} unpushed commit(s) for portability leaks:"))
    for line in log.stdout.splitlines()[:10]:
        print(f"  {line}")
    print()

    # Scan only added lines (+) in the unpushed diff; skip exempt meta-files
    diff_r = run_git("diff", "-U0", "HEAD@{upstream}..HEAD")
    leaks = []
    current_file = "(unknown)"
    skip_file = False
    for line in diff_r.stdout.splitlines():
        if line.startswith("+++ b/"):
            current_file = line[6:]
            skip_file = current_file in PORTABILITY_PUSH_EXEMPT
        elif not skip_file and line.startswith("+") and not line.startswith("+++"):
            content = line[1:]
            for pat, label in INTERNAL_PATTERNS:
                if re.search(pat, content, re.IGNORECASE):
                    leaks.append((current_file, content.rstrip(), label))
                    break

    if leaks:
        print(c(RED + BOLD, "⚠ PORTABILITY GATE FAILED — will not push to public GitHub:"))
        for file_path, content, label in leaks[:20]:
            print(c(RED, f"  [{label}] {file_path}:"))
            print(f"    {content[:120]}")
        print()
        print(c(YELLOW, "Strip internal markers then retry: walmart-sync --push"))
        sys.exit(1)

    print(c(GREEN, "  Portability gate: clean"))
    print()
    print(c(CYAN, f"Pushing ~/bin/ to {remote}/{branch}…"))
    r = run_git("push", remote, branch, capture=False)
    if r.returncode != 0:
        print()
        print(c(RED + BOLD, "⚠⚠ AGENT ALERT: git push failed."))
        sys.exit(1)
    print(c(GREEN + BOLD, f"✓ Pushed to {remote}/{branch}"))

# ---------------------------------------------------------------------------
# Check functions
# ---------------------------------------------------------------------------
def check_consistency(verbose=False):
    if not SHARED.exists():
        print(c(YELLOW, "  [skip] ~/src/relationship-shared not found — consistency check skipped (personal laptop?)"))
        return True
    all_ok = True
    for shared_rel, bin_rel, is_dir in MIRROR_ITEMS:
        src = SHARED / shared_rel
        dst = BIN / bin_rel
        label = bin_rel
        if not src.exists():
            print(c(YELLOW, f"  [warn] shared/{shared_rel} not found — item may have been removed or renamed"))
            continue
        if not dst.exists():
            print(c(RED, f"  [MISSING] {label} not in bin (exists in shared)"))
            all_ok = False
            continue
        if is_dir:
            result = subprocess.run(
                ["diff", "-rq", "--exclude=*.pyc", str(src), str(dst)],
                capture_output=True, text=True
            )
        else:
            result = subprocess.run(
                ["diff", str(src), str(dst)],
                capture_output=True, text=True
            )
        if result.returncode == 0:
            print(c(GREEN, f"  [ok] {label}"))
        else:
            print(c(RED, f"  [DRIFT] {label}"))
            if verbose and result.stdout:
                for dl in result.stdout.splitlines()[:30]:
                    print(f"        {dl}")
            all_ok = False
    return all_ok

def check_portability(verbose=False):
    all_ok = True
    checked = set()
    for _, bin_rel, is_dir in MIRROR_ITEMS:
        dst = BIN / bin_rel
        if not dst.exists():
            continue
        files = collect_files(dst) if is_dir else [dst]
        for f in files:
            if not f.is_file():
                continue
            hits = grep_patterns(f, INTERNAL_PATTERNS)
            rel = f.relative_to(BIN)
            if hits:
                print(c(RED, f"  [LEAK] {rel}"))
                for lineno, line, label in hits[:10]:
                    print(f"        L{lineno} [{label}]: {line[:120]}")
                all_ok = False
            elif verbose:
                print(c(GREEN, f"  [ok] {rel}"))
            checked.add(str(rel))
    return all_ok

def check_ref_integrity(verbose=False):
    all_ok = True
    for _, bin_rel, is_dir in MIRROR_ITEMS:
        dst = BIN / bin_rel
        if not dst.exists():
            continue
        files = collect_files(dst) if is_dir else [dst]
        for f in files:
            if not f.is_file():
                continue
            rel = f.relative_to(BIN)
            if str(rel) in REF_INTEGRITY_EXEMPT:
                if verbose:
                    print(c(GREEN, f"  [ok] {rel} (ref-integrity exempt)"))
                continue
            # Combine and deduplicate by line number (first label wins)
            seen_lines = set()
            raw_hits = (grep_patterns(f, REF_INTEGRITY_PATTERNS) +
                        grep_path_patterns(f, REF_INTEGRITY_PATH_PATTERNS))
            hits = []
            for h in raw_hits:
                if h[0] not in seen_lines:
                    hits.append(h)
                    seen_lines.add(h[0])
            if hits:
                print(c(YELLOW, f"  [ref?] {rel}"))
                for lineno, line, label in hits[:10]:
                    print(f"         L{lineno} [{label}]: {line[:120]}")
                all_ok = False
            elif verbose:
                print(c(GREEN, f"  [ok] {rel}"))
    return all_ok

def check_personal_only():
    """Confirm personal-only items exist in bin and are NOT in shared."""
    all_ok = True
    for item_rel in sorted(PERSONAL_ONLY):
        dst = BIN / item_rel
        if not dst.exists():
            print(c(YELLOW, f"  [warn] personal-only item missing from bin: {item_rel}"))
        else:
            if SHARED.exists():
                # warn if it leaked into shared
                src = SHARED / item_rel
                if src.exists():
                    print(c(RED, f"  [LEAK] personal-only item found in shared: {item_rel}"))
                    all_ok = False
                else:
                    print(c(GREEN, f"  [ok] {item_rel} (personal-only, not in shared)"))
    return all_ok

# ---------------------------------------------------------------------------
# Sync action
# ---------------------------------------------------------------------------
def do_sync(dry_run=False):
    if not SHARED.exists():
        print(c(RED, "Cannot sync: ~/src/relationship-shared not found"))
        return False

    if not block_if_managed_changes("sync"):
        return False
    print(c(CYAN, "Pre-sync pull sequence: shared first, then ~/bin."))
    if not pull_repo(SHARED, "~/src/relationship-shared"):
        return False
    if not pull_repo(BIN, "~/bin/"):
        return False

    changed = []
    for shared_rel, bin_rel, is_dir in MIRROR_ITEMS:
        src = SHARED / shared_rel
        dst = BIN / bin_rel
        if not src.exists():
            print(c(YELLOW, f"  [skip] shared/{shared_rel} not found"))
            continue
        if is_dir:
            result = subprocess.run(
                ["diff", "-rq", "--exclude=*.pyc", str(src), str(dst)],
                capture_output=True, text=True
            )
            in_sync = result.returncode == 0
        else:
            in_sync = dst.exists() and src.read_bytes() == dst.read_bytes()

        if in_sync:
            print(f"  [=] {bin_rel}")
        else:
            changed.append((shared_rel, bin_rel, is_dir, src, dst))
            print(c(YELLOW, f"  [→] {bin_rel}") + (" (would copy)" if dry_run else " (copying)"))
            if not dry_run:
                dst.parent.mkdir(parents=True, exist_ok=True)
                if is_dir:
                    if dst.exists():
                        shutil.rmtree(dst)
                    shutil.copytree(src, dst)
                else:
                    shutil.copy2(src, dst)

    if changed and not dry_run:
        print()
        print(c(CYAN, "Re-running portability check on updated items…"))
        all_ok = True
        for _, bin_rel, is_dir, _, dst in changed:
            files = collect_files(dst) if is_dir else [dst]
            for f in files:
                if not f.is_file():
                    continue
                hits = grep_patterns(f, INTERNAL_PATTERNS)
                rel = f.relative_to(BIN)
                if hits:
                    print(c(RED, f"  [LEAK] {rel} — review before committing!"))
                    for lineno, line, label in hits[:10]:
                        print(f"        L{lineno} [{label}]: {line[:120]}")
                    all_ok = False
        if all_ok:
            print(c(GREEN, "  Portability: clean — safe to commit"))
        else:
            print(c(RED, "  Portability: FAILURES — do NOT commit until resolved"))
    return True

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
usage_msg = """\
NAME
    walmart-sync — audit/sync ~/bin/ mirror; push on work laptop, pull on personal

SYNOPSIS
    walmart-sync [--consistency] [--portability] [--ref-integrity]
                 [--personal-only] [--sync [--dry-run]] [--push] [-v] [-h]

DESCRIPTION
    Behaviour depends on laptop context (detected via ~/src/relationship-shared):

    PERSONAL LAPTOP (shared absent):
      Default: enforce commit-first policy for walmart-sync-managed files,
      then pull from origin (merge, not rebase).

    WORK LAPTOP (shared present):
      Default (no flags): run three audits + personal-only check.

      Typical sync workflow:
        1. Commit local walmart-sync changes in ~/bin
        2. walmart-sync --sync          auto-pulls shared then ~/bin; copies drift
        3. git add -p && git commit     review and commit changes manually
        4. walmart-sync --push          portability gate, then push to origin

    Three audit checks:

    Consistency   Byte-diff bin copies vs relationship-shared originals.
                  Only meaningful on work laptop.

    Portability   Grep mirrored files for Walmart-internal markers (GHE
                  hostnames, internal Jira keys, etc.) that must not appear
                  in the public ~/bin GitHub repo.

    Ref-integrity Flag references to paths/skills that dangle on personal
                  laptop (e.g. ~/src/relationship-shared, shared/).

OPTIONS
    --consistency     Run consistency check only
    --portability     Run portability check only
    --ref-integrity   Run ref-integrity check only
    --personal-only   Check personal-only items
    --sync            Pull shared + ~/bin, copy drifted items, re-check portability
    --dry-run         With --sync: show what would change, don't write
    --push            Portability gate on unpushed commits, then push to origin
    -v, --verbose     Show passing items too
    -h, --help        Show this message

EXIT CODES
    0  All selected checks passed / pull or push succeeded
    1  One or more checks failed, or pull/push error
    2  Usage error (e.g. --push on personal laptop)

EXAMPLES
    walmart-sync                   # personal: pull; work: full audit
    walmart-sync -v                # full audit, show passing items
    walmart-sync --sync            # copy drifted items; then commit manually
    walmart-sync --sync --dry-run  # preview what would be synced
    walmart-sync --push            # portability gate + push committed state

MAINTENANCE
    When AgentRules.md §"Currently mirror-safe" changes, update MIRROR_ITEMS
    and PERSONAL_ONLY in this script to match.
"""

def main():
    p = argparse.ArgumentParser(add_help=False, usage=argparse.SUPPRESS)
    p.add_argument("--consistency",   action="store_true")
    p.add_argument("--portability",   action="store_true")
    p.add_argument("--ref-integrity", action="store_true")
    p.add_argument("--personal-only", action="store_true")
    p.add_argument("--sync",          action="store_true")
    p.add_argument("--push",          action="store_true")
    p.add_argument("--dry-run",       action="store_true")
    p.add_argument("-v", "--verbose", action="store_true")
    p.add_argument("-h", "--help",    action="store_true")
    args = p.parse_args()

    if args.help:
        print(usage_msg)
        sys.exit(0)

    on_work_laptop = SHARED.exists()

    if args.push:
        if not on_work_laptop:
            print(c(RED, "ERROR: --push requires ~/src/relationship-shared (work laptop only)"))
            sys.exit(2)
        print(c(BOLD, "── Push to origin ────────────────────────"))
        do_push()
        sys.exit(0)

    if args.sync:
        if not on_work_laptop:
            print(c(RED, "ERROR: --sync requires ~/src/relationship-shared (work laptop only)"))
            sys.exit(2)
        print(c(BOLD, "── Sync ──────────────────────────────────"))
        do_sync(dry_run=args.dry_run)
        if not args.dry_run:
            print()
            print(c(CYAN, "Sync done. Review, commit, then push:"))
            print(c(CYAN, "  cd ~/bin && git add -p && git commit && walmart-sync --push"))
        sys.exit(0)

    explicit_audit = any([args.consistency, args.portability,
                          getattr(args, "ref_integrity", False),
                          getattr(args, "personal_only", False)])

    # Personal laptop default (no explicit audit flags): just pull
    if not on_work_laptop and not explicit_audit:
        print(c(BOLD, "── Pull ~/bin/ from origin ───────────────"))
        do_pull()
        sys.exit(0)

    # Audit (work laptop, or explicit audit flags anywhere)
    run_all = not explicit_audit
    results = []

    if run_all or args.consistency:
        print(c(BOLD, "── Consistency (bin vs shared) ───────────"))
        results.append(check_consistency(verbose=args.verbose))

    if run_all or args.portability:
        print(c(BOLD, "── Portability (no internal markers) ────"))
        results.append(check_portability(verbose=args.verbose))

    if run_all or getattr(args, "ref_integrity", False):
        print(c(BOLD, "── Ref-integrity (no dangling refs) ─────"))
        results.append(check_ref_integrity(verbose=args.verbose))

    if run_all or getattr(args, "personal_only", False):
        print(c(BOLD, "── Personal-only items ───────────────────"))
        results.append(check_personal_only())

    print()
    if all(results):
        print(c(GREEN + BOLD, "✓ All checks passed"))
        sys.exit(0)
    else:
        print(c(RED + BOLD, "✗ One or more checks failed"))
        sys.exit(1)

if __name__ == "__main__":
    main()
