"""
walmart-sync — deterministic mirror audit/sync helper

Design:
- Thin orchestrator logic in this file
- Declarative policy/manifest in walmart-sync.json
"""

import argparse
import json
import re
import shutil
import subprocess
import sys
from pathlib import Path

BIN = Path.home() / "bin"
SHARED = Path.home() / "src" / "relationship-shared"
CFG_PATH = Path(__file__).with_suffix(".json")

GREEN = "\033[32m"
RED = "\033[31m"
YELLOW = "\033[33m"
CYAN = "\033[36m"
RESET = "\033[0m"
BOLD = "\033[1m"


def c(color, text):
    return f"{color}{text}{RESET}"


def run_git(repo: Path, *args, capture=True):
    cmd = ["git", "-C", str(repo)] + list(args)
    return subprocess.run(cmd, capture_output=capture, text=capture)


def load_cfg():
    try:
        return json.loads(CFG_PATH.read_text())
    except Exception as e:
        print(c(RED + BOLD, f"ERROR: cannot read {CFG_PATH}: {e}"))
        sys.exit(1)


def parse_porcelain_paths(text):
    paths = []
    for raw in text.splitlines():
        if len(raw) < 4:
            continue
        path = raw[3:]
        if " -> " in path:
            path = path.split(" -> ", 1)[1]
        paths.append(path.strip())
    return paths


def detect_upstream(repo: Path):
    r = run_git(repo, "rev-parse", "--abbrev-ref", "HEAD@{upstream}")
    if r.returncode == 0:
        parts = r.stdout.strip().split("/", 1)
        if len(parts) == 2:
            return parts[0], parts[1]
    b = run_git(repo, "branch", "--show-current")
    return "origin", (b.stdout.strip() or "main")


def compile_patterns(pattern_specs):
    return [(re.compile(pat, re.IGNORECASE), label) for pat, label in pattern_specs]


def collect_files(path: Path):
    if path.is_file():
        return [path]
    if path.is_dir():
        return sorted(path.rglob("*"))
    return []


def grep_patterns(path: Path, compiled, skip_url_lines=False):
    hits = []
    try:
        text = path.read_text(errors="replace")
    except Exception:
        return hits
    for lineno, line in enumerate(text.splitlines(), 1):
        if skip_url_lines and re.search(r"https?://", line, re.IGNORECASE):
            continue
        for rx, label in compiled:
            if rx.search(line):
                hits.append((lineno, line.rstrip(), label))
                break
    return hits


def walmart_sync_specs(cfg):
    exact = set(cfg.get("managed_exact", []))
    prefixes = [p.rstrip("/") + "/" for p in cfg.get("managed_prefixes", [])]
    for item in cfg["mirror_items"]:
        dst = item["bin_rel"]
        if item["is_dir"]:
            prefixes.append(dst.rstrip("/") + "/")
        else:
            exact.add(dst)
    for item in cfg["personal_only"]:
        if item.endswith("/"):
            prefixes.append(item.rstrip("/") + "/")
        else:
            exact.add(item)
    return exact, prefixes


def is_managed(path: str, exact, prefixes):
    if path in exact:
        return True
    return any(path.startswith(prefix) for prefix in prefixes)


def block_if_managed_changes(cfg, action_label: str):
    exact, prefixes = walmart_sync_specs(cfg)
    status = run_git(BIN, "status", "--porcelain")
    dirty = parse_porcelain_paths(status.stdout)
    managed = [p for p in dirty if is_managed(p, exact, prefixes)]
    if not managed:
        return True
    print(c(RED + BOLD, f"⚠ Commit-first policy: cannot {action_label} with local walmart-sync changes."))
    print(c(RED, "Commit these files first, then rerun walmart-sync:"))
    for p in managed:
        print(f"  - {p}")
    print()
    print(c(CYAN, "Suggested: cd ~/bin && git add <files> && git commit"))
    return False


def pull_repo(repo: Path, label: str):
    status = run_git(repo, "status", "--porcelain")
    dirty = parse_porcelain_paths(status.stdout)
    if dirty:
        print(c(RED + BOLD, f"⚠ Commit-first policy: cannot pull {label} with local changes."))
        print(c(RED, "Commit these files first, then rerun walmart-sync:"))
        for p in dirty:
            print(f"  - {p}")
        print()
        print(c(CYAN, f"Suggested: cd {repo} && git add <files> && git commit"))
        return False
    remote, branch = detect_upstream(repo)
    print(c(CYAN, f"Pulling {label} from {remote}/{branch} (merge)…"))
    r = run_git(repo, "pull", "--no-rebase", remote, branch, capture=False)
    if r.returncode != 0:
        print(c(RED + BOLD, f"⚠ Pull failed for {label}. Resolve and rerun."))
        return False
    return True


def check_consistency(cfg, verbose=False):
    if not SHARED.exists():
        print(c(YELLOW, "  [skip] shared repo not found"))
        return True
    all_ok = True
    for item in cfg["mirror_items"]:
        src = SHARED / item["shared_rel"]
        dst = BIN / item["bin_rel"]
        label = item["bin_rel"]
        if not src.exists():
            print(c(YELLOW, f"  [warn] missing in shared: {item['shared_rel']}"))
            continue
        if not dst.exists():
            print(c(RED, f"  [missing] {label}"))
            all_ok = False
            continue
        if item["is_dir"]:
            r = subprocess.run(["diff", "-rq", "--exclude=*.pyc", str(src), str(dst)],
                               capture_output=True, text=True)
            same = (r.returncode == 0)
        else:
            same = src.read_bytes() == dst.read_bytes()
            r = None
        if same:
            print(c(GREEN, f"  [ok] {label}"))
        else:
            print(c(RED, f"  [drift] {label}"))
            if verbose and r and r.stdout:
                for line in r.stdout.splitlines()[:20]:
                    print(f"    {line}")
            all_ok = False
    return all_ok


def iter_mirror_files(cfg):
    for item in cfg["mirror_items"]:
        dst = BIN / item["bin_rel"]
        if not dst.exists():
            continue
        for f in (collect_files(dst) if item["is_dir"] else [dst]):
            if f.is_file():
                yield f


def check_portability(cfg, verbose=False):
    compiled = compile_patterns(cfg["internal_patterns"])
    all_ok = True
    for f in iter_mirror_files(cfg):
        rel = f.relative_to(BIN)
        hits = grep_patterns(f, compiled)
        if hits:
            print(c(RED, f"  [leak] {rel}"))
            for ln, line, label in hits[:10]:
                print(f"    L{ln} [{label}]: {line[:120]}")
            all_ok = False
        elif verbose:
            print(c(GREEN, f"  [ok] {rel}"))
    return all_ok


def check_ref_integrity(cfg, verbose=False):
    compiled = compile_patterns(cfg["ref_integrity_patterns"])
    path_compiled = compile_patterns(cfg["ref_integrity_path_patterns"])
    exempt = set(cfg["ref_integrity_exempt"])
    all_ok = True
    for f in iter_mirror_files(cfg):
        rel = str(f.relative_to(BIN))
        if rel in exempt:
            if verbose:
                print(c(GREEN, f"  [ok] {rel} (exempt)"))
            continue
        raw = grep_patterns(f, compiled) + grep_patterns(f, path_compiled, skip_url_lines=True)
        dedup = {}
        for hit in raw:
            dedup.setdefault(hit[0], hit)
        hits = [dedup[k] for k in sorted(dedup.keys())]
        if hits:
            print(c(YELLOW, f"  [ref?] {rel}"))
            for ln, line, label in hits[:10]:
                print(f"    L{ln} [{label}]: {line[:120]}")
            all_ok = False
        elif verbose:
            print(c(GREEN, f"  [ok] {rel}"))
    return all_ok


def check_personal_only(cfg):
    all_ok = True
    for rel in sorted(cfg["personal_only"]):
        dst = BIN / rel
        if not dst.exists():
            print(c(YELLOW, f"  [warn] missing personal-only item: {rel}"))
            continue
        if SHARED.exists() and (SHARED / rel).exists():
            print(c(RED, f"  [leak] personal-only found in shared: {rel}"))
            all_ok = False
        else:
            print(c(GREEN, f"  [ok] {rel}"))
    return all_ok


def do_sync(cfg, dry_run=False):
    if not SHARED.exists():
        print(c(RED, "ERROR: --sync requires ~/src/relationship-shared"))
        return False
    if not block_if_managed_changes(cfg, "sync"):
        return False
    print(c(CYAN, "Pre-sync pull sequence: shared, then ~/bin"))
    if not pull_repo(SHARED, "~/src/relationship-shared"):
        return False
    if not pull_repo(BIN, "~/bin"):
        return False

    changed = []
    for item in cfg["mirror_items"]:
        src = SHARED / item["shared_rel"]
        dst = BIN / item["bin_rel"]
        if not src.exists():
            print(c(YELLOW, f"  [skip] missing in shared: {item['shared_rel']}"))
            continue
        if item["is_dir"]:
            r = subprocess.run(["diff", "-rq", "--exclude=*.pyc", str(src), str(dst)],
                               capture_output=True, text=True)
            in_sync = (r.returncode == 0)
        else:
            in_sync = dst.exists() and src.read_bytes() == dst.read_bytes()
        if in_sync:
            print(f"  [=] {item['bin_rel']}")
            continue
        changed.append(item["bin_rel"])
        print(c(YELLOW, f"  [→] {item['bin_rel']}") + (" (would copy)" if dry_run else " (copying)"))
        if dry_run:
            continue
        dst.parent.mkdir(parents=True, exist_ok=True)
        if item["is_dir"]:
            if dst.exists():
                shutil.rmtree(dst)
            shutil.copytree(src, dst)
        else:
            shutil.copy2(src, dst)

    if dry_run or not changed:
        return True

    print()
    print(c(CYAN, "Rechecking portability on changed items…"))
    compiled = compile_patterns(cfg["internal_patterns"])
    leak = False
    for rel in changed:
        p = BIN / rel
        files = collect_files(p) if p.is_dir() else [p]
        for f in files:
            if not f.is_file():
                continue
            hits = grep_patterns(f, compiled)
            if hits:
                leak = True
                show = str(f.relative_to(BIN))
                print(c(RED, f"  [leak] {show}"))
                for ln, line, label in hits[:10]:
                    print(f"    L{ln} [{label}]: {line[:120]}")
    if leak:
        print(c(RED, "Portability check failed after sync; do not commit yet."))
        return False
    print(c(GREEN, "Portability clean on synced changes."))
    return True


def do_push(cfg):
    if not SHARED.exists():
        print(c(RED, "ERROR: --push requires ~/src/relationship-shared"))
        return False
    if not block_if_managed_changes(cfg, "push"):
        return False

    remote, branch = detect_upstream(BIN)
    ahead_r = run_git(BIN, "rev-list", "--count", "HEAD@{upstream}..HEAD")
    if ahead_r.returncode != 0:
        print(c(RED, "Cannot determine upstream; set one first."))
        return False
    ahead = int(ahead_r.stdout.strip() or "0")
    if ahead == 0:
        print(c(YELLOW, "Nothing to push."))
        return True

    exempt = set(cfg["portability_push_exempt"])
    compiled = compile_patterns(cfg["internal_patterns"])
    diff_r = run_git(BIN, "diff", "-U0", "HEAD@{upstream}..HEAD")
    leaks = []
    current_file = "(unknown)"
    skip = False
    for line in diff_r.stdout.splitlines():
        if line.startswith("+++ b/"):
            current_file = line[6:]
            skip = current_file in exempt
            continue
        if skip or not line.startswith("+") or line.startswith("+++"):
            continue
        content = line[1:]
        for rx, label in compiled:
            if rx.search(content):
                leaks.append((current_file, content.rstrip(), label))
                break

    if leaks:
        print(c(RED + BOLD, "Portability push gate failed; refusing push."))
        for fp, line, label in leaks[:20]:
            print(c(RED, f"  [{label}] {fp}"))
            print(f"    {line[:120]}")
        return False

    print(c(CYAN, f"Pushing ~/bin to {remote}/{branch}…"))
    r = run_git(BIN, "push", remote, branch, capture=False)
    if r.returncode != 0:
        print(c(RED + BOLD, "Push failed."))
        return False
    print(c(GREEN + BOLD, "Push succeeded."))
    return True


def run_audit(cfg, args):
    run_all = not any([args.consistency, args.portability, args.ref_integrity, args.personal_only])
    results = []
    if run_all or args.consistency:
        print(c(BOLD, "── Consistency"))
        results.append(check_consistency(cfg, verbose=args.verbose))
    if run_all or args.portability:
        print(c(BOLD, "── Portability"))
        results.append(check_portability(cfg, verbose=args.verbose))
    if run_all or args.ref_integrity:
        print(c(BOLD, "── Ref-integrity"))
        results.append(check_ref_integrity(cfg, verbose=args.verbose))
    if run_all or args.personal_only:
        print(c(BOLD, "── Personal-only"))
        results.append(check_personal_only(cfg))
    ok = all(results) if results else True
    print()
    print(c((GREEN if ok else RED) + BOLD, "✓ All checks passed" if ok else "✗ One or more checks failed"))
    return ok


def parse_args():
    p = argparse.ArgumentParser(
        description="Audit/sync ~/bin mirror; push on work laptop, pull on personal"
    )
    p.add_argument("--consistency", action="store_true")
    p.add_argument("--portability", action="store_true")
    p.add_argument("--ref-integrity", action="store_true")
    p.add_argument("--personal-only", action="store_true")
    p.add_argument("--sync", action="store_true")
    p.add_argument("--push", action="store_true")
    p.add_argument("--dry-run", action="store_true")
    p.add_argument("-v", "--verbose", action="store_true")
    return p.parse_args()


def main():
    cfg = load_cfg()
    args = parse_args()
    on_work = SHARED.exists()

    if args.push:
        sys.exit(0 if do_push(cfg) else 1)

    if args.sync:
        sys.exit(0 if do_sync(cfg, dry_run=args.dry_run) else 1)

    explicit_audit = any([args.consistency, args.portability, args.ref_integrity, args.personal_only])
    if not on_work and not explicit_audit:
        if not block_if_managed_changes(cfg, "pull"):
            sys.exit(1)
        sys.exit(0 if pull_repo(BIN, "~/bin") else 1)

    sys.exit(0 if run_audit(cfg, args) else 1)


if __name__ == "__main__":
    main()
