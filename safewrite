def parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(add_help=False, exit_on_error=False)
    p.add_argument("target", help="Target file path")
    src = p.add_mutually_exclusive_group(required=True)
    src.add_argument("--from", dest="from_file", help="Path to file containing new content")
    src.add_argument("--stdin", action="store_true", help="Read new content from stdin")
    p.add_argument("--lock-root", default="/tmp/safewrite.locks", help="Directory for lock entries")
    p.add_argument("--ttl", type=int, default=120, help="Stale lock TTL in seconds")
    p.add_argument("--wait", type=int, default=30, help="Max seconds to wait for lock")
    p.add_argument("--owner", default=os.environ.get("USER", "unknown"), help="Owner label in lock metadata")
    p.add_argument("--allow-empty-write", action="store_true",
                   help="Allow 0-byte writes to non-empty target files (default: blocked)")
    p.add_argument("--backup-to", default=None,
                   help="Backup destination path; directory or filename")
    p.add_argument("--max-shrink-pct", type=float, default=None,
                   help="Abort if output shrinks by more than this percent versus current target")
    p.add_argument("--sentinel-regex", default=None,
                   help="Require regex to match output before write")
    p.add_argument("--expect-sha256", dest="expect_sha256", default=None,
                   help="SHA-256 of the file as the caller read it; write aborts if file has changed (CAS)")
    p.add_argument("--note", default="",
                   help="Free-form advisory text stored in the lock (agent name, task ID, prompt summary, etc.)")
    return p.parse_args()


def main() -> int:
    # Pre-scan for help flags only in the first argument position to avoid
    # false positives when -h/-H appear as option values (e.g. --note "-h").
    if len(sys.argv) > 1 and sys.argv[1] in ("-H", "--raw-help"):
        sys.stdout.write(usage_msg)
        return 0
    if len(sys.argv) > 1 and sys.argv[1] in ("-h", "--help"):
        show_usage()
        return 0
    try:
        args = parse_args()
    except (argparse.ArgumentError, SystemExit):
        print("usage: safewrite TARGET (--from SOURCE | --stdin) [OPTIONS]", file=sys.stderr)
        print("Run 'safewrite -h' for help.", file=sys.stderr)
        return 1
    target = Path(args.target).expanduser()
    lock_root = Path(args.lock_root).expanduser()

    if args.stdin:
        new_data = sys.stdin.buffer.read()
    else:
        new_data = Path(args.from_file).expanduser().read_bytes()

    # Default protection: block accidental zeroing of non-empty targets for both --stdin and --from.
    if len(new_data) == 0 and target.exists() and target.stat().st_size > 0 and not args.allow_empty_write:
        source_hint = "--stdin" if args.stdin else f"--from {args.from_file}"
        print(
            f"FATAL: {source_hint} produced 0 bytes but {target} is non-empty "
            f"({target.stat().st_size} bytes). Refusing to zero the file. "
            f"Pass --allow-empty-write to intentionally permit this.",
            file=sys.stderr,
        )
        return 1

    if args.max_shrink_pct is not None and args.max_shrink_pct < 0:
        print("usage error: --max-shrink-pct must be >= 0", file=sys.stderr)
        return 1

    if args.sentinel_regex is not None:
        try:
            sentinel_pattern = re.compile(args.sentinel_regex)
        except re.error as exc:
            print(f"usage error: invalid --sentinel-regex: {exc}", file=sys.stderr)
            return 1
        new_text = new_data.decode("utf-8", errors="replace")
        if sentinel_pattern.search(new_text) is None:
            print(
                f"FATAL: --sentinel-regex did not match output for {target}. Refusing to write.",
                file=sys.stderr,
            )
            return 1

    lock_path = acquire_lock(lock_root, target, ttl=args.ttl, wait_s=args.wait, owner=args.owner, note=args.note)
    if lock_path is None:
        print(f"Failed to acquire lock for {target} within {args.wait}s", file=sys.stderr)
        return 2

    stop_evt = threading.Event()
    hb = start_heartbeat(lock_path, stop_evt)

    try:
        if args.expect_sha256 is not None:
            current_sha256 = fingerprint(target)["sha256"]
            if current_sha256 != args.expect_sha256:
                print(
                    f"CAS mismatch for {target}: expected {args.expect_sha256}, found {current_sha256}",
                    file=sys.stderr,
                )
                return 3

        if args.backup_to:
            backup_path = resolve_backup_path(args.backup_to, target)
            write_backup_file(backup_path, read_bytes(target))
            print(f"Wrote backup to {backup_path}")

        if args.max_shrink_pct is not None:
            current_size = target.stat().st_size if target.exists() else 0
            new_size = len(new_data)
            if current_size > 0 and new_size < current_size:
                shrink_pct = ((current_size - new_size) / current_size) * 100.0
                if shrink_pct > args.max_shrink_pct:
                    print(
                        f"FATAL: --max-shrink-pct={args.max_shrink_pct:g} exceeded for {target}: "
                        f"{shrink_pct:.2f}% shrink ({current_size} -> {new_size} bytes).",
                        file=sys.stderr,
                    )
                    return 1

        write_in_place(target, new_data)

        final_data = read_bytes(target)
        if sha256_bytes(final_data) != sha256_bytes(new_data):
            print(f"Verification failed after write for {target}", file=sys.stderr)
            return 4

        print(f"Wrote {len(new_data)} bytes safely to {target}")
        return 0
    finally:
        stop_evt.set()
        hb.join(timeout=1.0)
        release_lock(lock_path)


if __name__ == "__main__":
    raise SystemExit(main())
